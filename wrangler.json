{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "astro-boilerplate-marketing-website",
  "main": "@astrojs/cloudflare/entrypoints/server",
  "compatibility_date": "2026-02-28",
  "placement": {
    "mode": "smart"
  },
  "assets": {
    "binding": "ASSETS",
    "directory": "./dist"
  },
  "observability": {
    "enabled": true
  },
  "compatibility_flags": ["nodejs_compat"]
}
