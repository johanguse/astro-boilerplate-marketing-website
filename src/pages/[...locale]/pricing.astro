---
import type { GetStaticPaths } from "astro";
import { DEFAULT_LOCALE, SUPPORTED_LOCALES } from "@/i18n/config";
import { translateFor } from "@/i18n/utils";

export const prerender = true;

import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import PricingSection from "@/components/sections/PricingSection.astro";
import StatsSection from "@/components/sections/StatsSection.astro";
import CTASection from "@/components/sections/CTASection.astro";

export const getStaticPaths = (async () =>
  SUPPORTED_LOCALES.map((locale) => ({
    params: { locale: locale === DEFAULT_LOCALE ? undefined : locale },
  }))) satisfies GetStaticPaths;

const { locale = DEFAULT_LOCALE } = Astro.params;
const t = translateFor(Astro.currentLocale);

const plans = [
  {
    name: t("pricing.plan.free.name"),
    price: "$0",
    period: t("pricing.period.month"),
    description: t("pricing.plan.free.description"),
    badge: undefined,
    popular: false,
    cta: t("pricing.plan.free.cta"),
    ctaHref: "/signup",
    features: [
      { text: t("pricing.feature.aiCredits", { count: "10" }), included: true },
      { text: t("pricing.feature.docIntel"), included: true },
      { text: t("pricing.feature.projects", { count: "1" }).split("|")[0], included: true },
      { text: t("pricing.feature.users", { count: "1" }).split("|")[0], included: true },
      { text: t("pricing.feature.storage", { amount: "1GB" }), included: true },
      { text: t("pricing.feature.contentGen"), included: false },
      { text: t("pricing.feature.analytics"), included: false },
      { text: t("pricing.feature.api"), included: false },
    ],
  },
  {
    name: t("pricing.plan.starter.name"),
    price: "$9.90",
    period: t("pricing.period.month"),
    description: t("pricing.plan.starter.description"),
    badge: undefined,
    popular: false,
    cta: t("pricing.plan.starter.cta"),
    ctaHref: "/signup?plan=starter",
    features: [
      { text: t("pricing.feature.aiCredits", { count: "1,000" }), included: true },
      { text: t("pricing.feature.docIntel"), included: true },
      { text: t("pricing.feature.contentGen"), included: true },
      { text: t("pricing.feature.projects", { count: "1" }).split("|")[0], included: true },
      { text: t("pricing.feature.users", { count: "3" }).split("|")[1], included: true },
      { text: t("pricing.feature.storage", { amount: "5GB" }), included: true },
      { text: t("pricing.feature.analytics"), included: false },
      { text: t("pricing.feature.api"), included: false },
    ],
  },
  {
    name: t("pricing.plan.pro.name"),
    price: "$29.90",
    period: t("pricing.period.month"),
    description: t("pricing.plan.pro.description"),
    badge: t("pricing.plan.pro.badge"),
    popular: true,
    cta: t("pricing.plan.pro.cta"),
    ctaHref: "/signup?plan=professional",
    features: [
      { text: t("pricing.feature.aiCredits", { count: "5,000" }), included: true },
      { text: t("pricing.feature.docIntel"), included: true },
      { text: t("pricing.feature.contentGen"), included: true },
      { text: t("pricing.feature.analytics"), included: true },
      { text: t("pricing.feature.projects", { count: "5" }).split("|")[1], included: true },
      { text: t("pricing.feature.users", { count: "10" }).split("|")[1], included: true },
      { text: t("pricing.feature.storage", { amount: "20GB" }), included: true },
      { text: t("pricing.feature.api"), included: false },
    ],
  },
  {
    name: t("pricing.plan.business.name"),
    price: "$99.90",
    period: t("pricing.period.month"),
    description: t("pricing.plan.business.description"),
    badge: undefined,
    popular: false,
    cta: t("pricing.plan.business.cta"),
    ctaHref: locale === DEFAULT_LOCALE ? "/contact" : `/${locale}/contact`,
    features: [
      { text: t("pricing.feature.aiCredits", { count: "25,000" }), included: true },
      { text: t("pricing.feature.docIntel"), included: true },
      { text: t("pricing.feature.contentGen"), included: true },
      { text: t("pricing.feature.analytics"), included: true },
      { text: t("pricing.feature.projects", { count: "20" }).split("|")[1], included: true },
      { text: t("pricing.feature.users", { count: "50" }).split("|")[1], included: true },
      { text: t("pricing.feature.storage", { amount: "100GB" }), included: true },
      { text: t("pricing.feature.fullApi"), included: true },
    ],
  },
];

const stats = [
  { value: "99.9", suffix: "%", label: t("home.stats.uptime") },
  { value: "10M+", suffix: "", label: t("home.stats.operations") },
  { value: "5K+", suffix: "", label: t("home.stats.customers") },
  { value: "24/7", suffix: "", label: t("home.stats.support") },
];
---

<Layout title={t("pricing.meta.title")} description={t("pricing.meta.description")}>
  <Header />
  <main>
    <!-- Hero Section -->
    <section class="relative overflow-hidden py-20 md:py-32 bg-gradient-mesh">
      <div class="container max-w-4xl text-center">
        <h1 class="text-5xl font-bold tracking-tight sm:text-6xl md:text-7xl mb-6 animate-slide-up">
          {t("pricing.hero.title")}
        </h1>
        <p class="text-xl text-muted-foreground mb-8 animate-fade-in">
          {t("pricing.hero.subtitle")}
        </p>
      </div>
    </section>

    <!-- Pricing Cards -->
    <PricingSection
      title={t("pricing.section.title")}
      subtitle={t("pricing.section.subtitle")}
      plans={plans}
    />

    <!-- Stats -->
    <StatsSection
      title={t("home.stats.title")}
      subtitle={t("home.stats.subtitle")}
      stats={stats}
    />

    <!-- FAQ Section -->
    <section class="py-20 md:py-32 bg-muted/30">
      <div class="container max-w-4xl">
        <h2 class="text-4xl font-bold tracking-tight text-center mb-16">
          {t("pricing.faq.title")}
        </h2>

        <div class="space-y-8">
          <div>
            <h3 class="text-xl font-semibold mb-3">{t("pricing.faq.credits.q")}</h3>
            <p class="text-muted-foreground leading-relaxed">
              {t("pricing.faq.credits.a")}
            </p>
          </div>

          <div>
            <h3 class="text-xl font-semibold mb-3">{t("pricing.faq.change.q")}</h3>
            <p class="text-muted-foreground leading-relaxed">
              {t("pricing.faq.change.a")}
            </p>
          </div>

          <div>
            <h3 class="text-xl font-semibold mb-3">{t("pricing.faq.exceed.q")}</h3>
            <p class="text-muted-foreground leading-relaxed">
              {t("pricing.faq.exceed.a")}
            </p>
          </div>

          <div>
            <h3 class="text-xl font-semibold mb-3">{t("pricing.faq.refund.q")}</h3>
            <p class="text-muted-foreground leading-relaxed">
              {t("pricing.faq.refund.a")}
            </p>
          </div>

          <div>
            <h3 class="text-xl font-semibold mb-3">{t("pricing.faq.apiKey.q")}</h3>
            <p class="text-muted-foreground leading-relaxed">
              {t("pricing.faq.apiKey.a")}
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <CTASection
      title={t("pricing.cta.title")}
      subtitle={t("pricing.cta.subtitle")}
      primaryCta={t("pricing.cta.primary")}
      primaryCtaHref="/signup"
      secondaryCta={t("pricing.cta.secondary")}
      secondaryCtaHref={locale === DEFAULT_LOCALE ? "/contact" : `/${locale}/contact`}
      variant="gradient"
    />
  </main>
  <Footer />
</Layout>
