---
import type { GetStaticPaths } from "astro";
import { DEFAULT_LOCALE, SUPPORTED_LOCALES } from "@/i18n/config";
import { translateFor } from "@/i18n/utils";

export const prerender = true;

import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { Badge } from "@/components/ui/badge";
import FeatureGrid from "@/components/sections/FeatureGrid.astro";
import { FeatureTabs } from "@/components/FeatureTabs";
import CTASection from "@/components/sections/CTASection.astro";

export const getStaticPaths = (async () =>
  SUPPORTED_LOCALES.map((locale) => ({
    params: { locale: locale === DEFAULT_LOCALE ? undefined : locale },
  }))) satisfies GetStaticPaths;

const { locale = DEFAULT_LOCALE } = Astro.params;
const t = translateFor(Astro.currentLocale);

const aiFeatures = [
  {
    icon: "📄",
    title: t("features.ai.docIntel.title"),
    description: t("features.ai.docIntel.desc"),
  },
  {
    icon: "✍️",
    title: t("features.ai.contentGen.title"),
    description: t("features.ai.contentGen.desc"),
  },
  {
    icon: "📊",
    title: t("features.ai.analytics.title"),
    description: t("features.ai.analytics.desc"),
  },
  {
    icon: "🔍",
    title: t("features.ai.search.title"),
    description: t("features.ai.search.desc"),
  },
  {
    icon: "🌐",
    title: t("features.ai.multiLang.title"),
    description: t("features.ai.multiLang.desc"),
  },
  {
    icon: "🔌",
    title: t("features.ai.providers.title"),
    description: t("features.ai.providers.desc"),
  },
];

const technicalFeatures = [
  {
    icon: "🔐",
    title: t("features.tech.security.title"),
    description: t("features.tech.security.desc"),
  },
  {
    icon: "⚡",
    title: t("features.tech.realtime.title"),
    description: t("features.tech.realtime.desc"),
  },
  {
    icon: "📱",
    title: t("features.tech.api.title"),
    description: t("features.tech.api.desc"),
  },
  {
    icon: "🎨",
    title: t("features.tech.ui.title"),
    description: t("features.tech.ui.desc"),
  },
  {
    icon: "📈",
    title: t("features.tech.usage.title"),
    description: t("features.tech.usage.desc"),
  },
  {
    icon: "🔄",
    title: t("features.tech.async.title"),
    description: t("features.tech.async.desc"),
  },
];
---

<Layout title={t("features.meta.title")} description={t("features.meta.description")}>
  <Header />
  <main>
    <!-- Hero Section -->
    <section class="relative overflow-hidden py-20 md:py-32 bg-gradient-mesh">
      <div class="container max-w-5xl text-center">
        <Badge variant="secondary" className="mb-6 px-4 py-2" client:load>
          {t("features.hero.badge")}
        </Badge>

        <h1 class="text-5xl font-bold tracking-tight sm:text-6xl md:text-7xl mb-6 animate-slide-up">
          {t("features.hero.title")}
        </h1>

        <p class="text-xl text-muted-foreground mb-10 max-w-3xl mx-auto animate-fade-in">
          {t("features.hero.subtitle")}
        </p>
      </div>
    </section>

    <!-- AI Features -->
    <FeatureGrid
      title={t("features.ai.title")}
      subtitle={t("features.ai.subtitle")}
      features={aiFeatures}
    />

    <!-- Feature Tabs -->
    <section class="py-20 md:py-32 bg-muted/30">
      <div class="container max-w-6xl">
        <div class="text-center mb-16">
          <h2 class="text-4xl font-bold tracking-tight sm:text-5xl mb-4">
            {t("features.tabs.title")}
          </h2>
          <p class="text-xl text-muted-foreground">
            {t("features.tabs.subtitle")}
          </p>
        </div>

        <FeatureTabs client:load />
      </div>
    </section>

    <!-- Technical Features -->
    <FeatureGrid
      title={t("features.tech.title")}
      subtitle={t("features.tech.subtitle")}
      features={technicalFeatures}
    />

    <!-- CTA -->
    <CTASection
      title={t("features.cta.title")}
      subtitle={t("features.cta.subtitle")}
      primaryCta={t("cta.startFreeTrial")}
      primaryCtaHref="/signup"
      secondaryCta={t("cta.viewPricing")}
      secondaryCtaHref={locale === DEFAULT_LOCALE ? "/pricing" : `/${locale}/pricing`}
      variant="gradient"
    />
  </main>
  <Footer />
</Layout>
